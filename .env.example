# Kalshi API Credentials
KALSHI_API_KEY_ID=your-api-key-uuid
# Path to the RSA Private Key in PEM format (do not store the key contents directly in env)
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private.pem
# Environment: 'demo' or 'prod'
KALSHI_ENV=demo

# Trading Mode
# When True, orders are simulated and logged but not sent to the exchange
SHADOW_MODE=True
# Production safety guard: set to 1 only after confirming shadow mode logs look correct
# LIVE_TRADE_CONFIRMED=1

# API version for path construction (override via env for version negotiation)
# KALSHI_API_VERSION=v2

# FRED API Key (for macroeconomic data)
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage API Key (fallback alternative data provider)
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Market Configuration
KALSHI_TICKER=FED-24DEC-T4.00
KALSHI_SECTOR=Economics
MACRO_INDICATOR=CPI
POLL_INTERVAL_SEC=60

# Risk Constraints
MAX_VAR_LIMIT_PCT=0.02
MAX_SECTOR_LIMIT_PCT=0.30
KELLY_MULTIPLIER=0.25

# Strategy Conviction Calibration
# Slope for scaling conviction from signal strength (default 0.12)
CONVICTION_SLOPE=0.12
# Maximum conviction change per signal (default 0.35)
CONVICTION_MAX_DELTA=0.35

# Minimum Signal Quality Thresholds
# Minimum z-score conviction sigma to trigger a trade (default 1.0)
MIN_CONVICTION_SIGMA=1.0
# Maximum bid-ask spread % to accept a trade (default 0.05 = 5%)
MAX_SPREAD_PCT=0.05

# Position Management
# Trailing stop-loss percentage below highest price (default 10%)
TRAILING_STOP_PCT=0.10
# Take-profit tier 1: 2:1 reward-to-risk, exit 50% of position
TAKE_PROFIT_TIER_1_MULTIPLIER=2.0
TAKE_PROFIT_TIER_1_FRACTION=0.50
# Take-profit tier 2: 3:1 reward-to-risk, exit 75% of position
TAKE_PROFIT_TIER_2_MULTIPLIER=3.0
TAKE_PROFIT_TIER_2_FRACTION=0.75
# How often to rebalance positions (seconds, default 300)
POSITION_REBALANCE_INTERVAL_SEC=300.0

# Trade Cooldown
# Don't trade the same indicator more than once per window (seconds, default 3600 = 1hr)
TRADE_COOLDOWN_SEC=3600.0

# Safety Balance Monitor (Kill Switch triggers if balance falls below this)
KILL_SWITCH_MIN_BALANCE=100.00

# Network & Retry
REQUEST_TIMEOUT_SEC=10.0
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SEC=1.0

# Observability
LOG_LEVEL=INFO
HEALTH_PORT=8080
